rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Any signed-in user can read/write photos. Storage rules can't easily
    // check the Firestore role doc the way Firestore rules can, so this
    // stays at "must be logged in" rather than per-role — reasonable for a
    // small trusted team where every login is one you created yourself.
    match /machines/{machineId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
